# Vercel template for frontend environment variables.
# In Vercel Dashboard -> Project -> Settings -> Environment Variables,
# create each VITE_* variable for Production and Preview.

# Backend target for cloud deploy
VITE_BACKEND_TARGET=development
VITE_RUNTIME_MODE=develop

# Optional explicit override. Keep empty when using target-based defaults.
VITE_STRAPI_URL=

# Target-based defaults
VITE_STRAPI_URL_LOCAL=http://localhost:1337
VITE_STRAPI_URL_DEVELOPMENT=https://connectra-backend-system-f4a977a741b9.herokuapp.com
VITE_STRAPI_URL_DEVELOP=https://connectra-backend-system-f4a977a741b9.herokuapp.com

# Auth/User endpoints
VITE_STRAPI_AUTH_ENDPOINT=/api/auth/local
VITE_STRAPI_REGISTER_ENDPOINT=/api/auth/local/register
VITE_STRAPI_FORGOT_PASSWORD_ENDPOINT=/api/auth/forgot-password
VITE_STRAPI_USERS_ENDPOINT=/api/users

# ConnectTroca API collections
VITE_STRAPI_PROFILES_ENDPOINT=/api/profiles
VITE_STRAPI_AREAS_ENDPOINT=/api/areas
VITE_STRAPI_GROUPS_ENDPOINT=/api/groups
VITE_STRAPI_GROUP_MEMBERS_ENDPOINT=/api/group-members
VITE_STRAPI_USER_AREAS_ENDPOINT=/api/user-areas
VITE_STRAPI_MATERIALS_ENDPOINT=/api/materials
VITE_STRAPI_TOPICS_ENDPOINT=/api/topics
VITE_STRAPI_POSTS_ENDPOINT=/api/posts
VITE_STRAPI_COMMENTS_ENDPOINT=/api/comments
VITE_STRAPI_LIKES_ENDPOINT=/api/likes

# Legacy compatibility endpoint
VITE_STRAPI_ACTIVITIES_ENDPOINT=/api/topics
